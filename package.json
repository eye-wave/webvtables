{
  "name": "webvtabes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"bun run dev:rust\"",
    "dev:rust": "cargo watch -w src -x \"build --target wasm32-unknown-unknown --release\"",
    "build": "bun run build:rust && vite build",
    "build:rust": "cargo build --target wasm32-unknown-unknown --release",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "concurrently": "^10.0.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-glsl": "^1.6.0"
  }
}
